# Base URL for the cheongyak backend API — SERVER ONLY.
# Do NOT use the NEXT_PUBLIC_ prefix; the browser must never see this host.
# Browser-side calls go through /api/backend/* which next.config.ts rewrites
# to this origin server-side (same-origin from the browser's view).
# Must start with https:// (or http://localhost for local dev proxies).
API_BACKEND_URL=https://api.example.com

# OpenAPI JSON URL consumed by `pnpm codegen` (orval).
# The real URL lives in .env.local; commit only the placeholder.
# See .claude/api-docs.local.md (gitignored) for the actual value.
OPENAPI_URL=https://api.example.com/api-docs/user

# Kakao JavaScript SDK key — used by the listing-detail share button.
# Get one at https://developers.kakao.com → My Application → JavaScript key.
# Optional: when missing, the Kakao share button no-ops with a console warning.
# Must be the JavaScript key (browser-safe), not the REST/Admin key.
NEXT_PUBLIC_KAKAO_JS_KEY=

# Canonical site origin used by sitemap, canonical/OG metadata, JSON-LD,
# and the share button's clipboard URL. REQUIRED — no fallback in code,
# missing env throws at boot. Production / preview / development on Vercel
# all set this to https://cheongyak.com (preview is noindex anyway). Local
# .env.local sets it to http://localhost:715 so share testing in dev copies
# the local URL.
NEXT_PUBLIC_SITE_URL=https://your-domain.example.com
