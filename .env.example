# Base URL for the cheongyak backend API — SERVER ONLY.
# Do NOT use the NEXT_PUBLIC_ prefix; the browser must never see this host.
# Browser-side calls go through /api/backend/* which next.config.ts rewrites
# to this origin server-side (same-origin from the browser's view).
# Must start with https:// (or http://localhost for local dev proxies).
API_BACKEND_URL=https://api.example.com

# OpenAPI JSON URL consumed by `pnpm codegen` (orval).
# The real URL lives in .env.local; commit only the placeholder.
# See .claude/api-docs.local.md (gitignored) for the actual value.
OPENAPI_URL=https://api.example.com/api-docs/user
